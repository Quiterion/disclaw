#!/usr/bin/env bash
# disclaw-ctl wrapper — invokable from any cwd.
# Resolves the repo root from this script's location and runs ctl.ts via tsx.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
exec node --import tsx "$REPO_ROOT/src/ctl.ts" "$@"
