#!/usr/bin/env bash
# pi-discord-ctl wrapper — invokable from any cwd.
#
# Resolves the package root from this script's location. Prefers the
# built JS at dist/ctl.js; falls back to tsx for dev convenience when
# dist/ is absent.
set -euo pipefail
# Resolve symlinks so workspace-root bin/pi-discord-ctl (a symlink to
# this file) still points us at the right package root.
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
PKG_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$PKG_ROOT/dist/ctl.js" ]]; then
  exec node "$PKG_ROOT/dist/ctl.js" "$@"
fi
exec node --import tsx "$PKG_ROOT/src/ctl.ts" "$@"
