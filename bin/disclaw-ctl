#!/usr/bin/env bash
# disclaw-ctl wrapper — invokable from any cwd.
#
# Resolves the repo root from this script's location. Prefers the built
# JS at dist/ctl.js (zero runtime deps in the sandbox); falls back to
# tsx for dev convenience when dist/ is absent (e.g. fresh clone before
# `npm run build`).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$REPO_ROOT/dist/ctl.js" ]]; then
  exec node "$REPO_ROOT/dist/ctl.js" "$@"
fi
exec node --import tsx "$REPO_ROOT/src/ctl.ts" "$@"
