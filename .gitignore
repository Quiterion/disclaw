.env
**/__pycache__
**/node_modules
**/dist
**/tsconfig.tsbuildinfo
*.log

# Stale runtime dir from the pre-monorepo daemon (DISCLAW_RUNTIME_DIR =
# ~/.disclaw by default). Harmless; safe to delete.
.disclaw/

# Per-package isolated runtime dirs sometimes used during dev (e.g.
# dev-test.sh seeds these into a timestamped TEST_DIR — that lives
# under ~/pi-host-tests, but a stray relative path could land here).
.pi-host/
.pi-discord/

# Agent-written artifacts that may land in cwd (e.g. feedback.md from
# a testing instance writing per welcome.testing.md). Track manually
# if a particular one is worth preserving.
feedback.md
